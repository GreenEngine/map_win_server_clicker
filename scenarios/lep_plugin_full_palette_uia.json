{
  "id": "lep_plugin_full_palette_uia",
  "title": "LEP: все главные вкладки + подвкладки Трасса (включая КЛ 6–20/0.4/Экран СПЭ), UIA automation_id, снимки после каждого клика",
  "version": 1,
  "stop_on_first_error": false,
  "skip_nanocad_lep_prepare": false,
  "requires": {
    "golden_dwg": false,
    "note": "Соответствует ALL/Docs/QA_UiaIds.md. При частичных ERR_NOT_FOUND сценарий всё равно доходит до конца (stop_on_first_error=false)."
  },
  "steps": [
    {
      "n": 1,
      "invoke": "health",
      "args": {},
      "expect": "ok"
    },
    {
      "n": 2,
      "invoke": "agent_session",
      "args": {},
      "expect": "ревизии MCP"
